{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "noEmit": true
  },
  "include": ["src", "tests", "__mocks__"],
  "exclude": ["node_modules", ".vscode-test", "out"]
}
